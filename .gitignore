# Reference https://github.com/github/gitignore/blob/master/Go.gitignore
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.dylib
.idea

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
vendor/

# Go workspace file
go.work

# Compiled Object files, Static and Dynamic libs (Shared Objects)
*.o
*.a
*.so

# OS General
Thumbs.db
.DS_Store

# project
*.cert
*.key
*.log
bin/
/data-service
.gocache*

# production data config
config.data.prod.yaml

# Develop tools
.vscode/
.idea/
.claude/
*.swp
.cursor/
# Python
__pycache__/
.pycache
.ace-tool

docs/reference/

examples/PD-001/mqtt/.*
examples/PD-001/takeover_order_vendor/.*

configs/config.app.local.yaml
configs/config.data.local.yaml

# LLM batch script output
scripts/llm/llm-created-jobs.jsonl
scripts/llm/llm-create-failed.jsonl

# Agent
AGENTS.md
CLAUDE.md
opencode.json

# Generated by make api
openapi.yaml
